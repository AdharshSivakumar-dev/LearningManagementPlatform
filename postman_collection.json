                "localhost"
              ],
              "port": "8001",
              "path": [
                "login",
                ""
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"john@example.com\",\n  \"password\": \"snow1234\"\n}"
            }
          }
        },
        {
          "name": "Token (OAuth2 Password Flow)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "url": {
              "raw": "http://localhost:8001/token/",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8001",
              "path": [
                "token",
                ""
              ]
            },
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "john@example.com"
                },
                {
                  "key": "password",
                  "value": "snow1234"
                }
              ]
            }
          }
        }
      ]
