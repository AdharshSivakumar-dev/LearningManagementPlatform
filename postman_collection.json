                "auth",
                "otp",
                "send",
                ""
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"name\": \"Jane Doe\",\n  \"role\": \"student\"\n}"
