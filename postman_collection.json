                "otp",
                "verify",
                ""
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"otp_code\": \"123456\"\n}"
            },
            "description": "Verify OTP code. Returns JWT and user info. Creates user if not already registered."
          }
