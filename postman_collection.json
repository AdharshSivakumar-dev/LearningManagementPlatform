            "url": {
              "raw": "http://localhost:8001/register/",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8001",
              "path": [
                "register",
                ""
              ]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Snow\",\n  \"email\": \"john@example.com\",\n  \"password\": \"snow1234\",\n  \"role\": \"student\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
